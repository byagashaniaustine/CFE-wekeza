# WhatsApp Cloud API credentials (Meta for Developers > your app > WhatsApp > API Setup)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Any secret string; must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=
PORT=8000
# Anthropic API key — enables Claude-powered conversational Q&A (the "Ask a Question" journey)
ANTHROPIC_API_KEY=
# WhatsApp Flows (optional). Leave blank to run modules as message screens.
# Each ready module has its own static Flow: assets/flows/<moduleId>-<lang>.flow.json.
# Publish each in Meta, then map "<moduleId>-<lang>" → Flow id here as JSON, e.g.:
#   FLOW_IDS={"basic-concepts-en":"123","basic-concepts-sw":"456","why-invest-en":"789"}
FLOW_IDS=
# Optional: enables the dynamic single-Flow /flow endpoint (unencrypted PKCS8 key).
FLOW_PRIVATE_KEY=
# Per-module / academy approved templates. Sensible defaults (your WhatsApp Manager
# names) are baked into main.ts, so these are OPTIONAL overrides. All sent as "en".
#   MODULE_TEMPLATES={"basic-concepts-en":"cfe_modules","basic-concepts-sw":"basic_module1_sw"}
#   ACADEMY_TEMPLATES={"utt":"product_library1","dse":"product_library2"}
MODULE_TEMPLATES=
ACADEMY_TEMPLATES=
