# WhatsApp Cloud API credentials (Meta for Developers > your app > WhatsApp > API Setup)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Any secret string; must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=
PORT=8000
ANTHROPIC_API_KEY=
# Gemini fallback — used when Claude is unavailable or errors
GEMINI_API_KEY=

# Streamlogia log ingest (https://api.streamlogia.com/v1/ingest). Leave the key
# or project id blank to disable shipping — the bot then only logs to stdout.
STREAMLOGIA_API_KEY=
STREAMLOGIA_PROJECT_ID=
# Optional: source label attached to every event (defaults to "cfe-invest-bot").
STREAMLOGIA_SOURCE=
# Optional: override the ingest endpoint (defaults to https://api.streamlogia.com/v1/ingest).
STREAMLOGIA_ENDPOINT=
